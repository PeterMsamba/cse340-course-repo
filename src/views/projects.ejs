<%- include('partials/header') %>
  <main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    
    <% if (projects && projects.length > 0) { %>
      <ul>
        <% projects.forEach(project => { %>
          <li>
            <strong>
              <%= new Date(project.date).toLocaleDateString('en-US', { 
                  month: 'long', 
                  day: 'numeric', 
                  year: 'numeric',
                  timeZone: 'UTC' 
              }) %>:
            </strong>
            <a href="/project/<%= project.project_id %>"><%= project.title %></a> 
            
            <span>(<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)</span>
            
            <p style="margin: 0.5rem 0 0 0; font-size: 0.95rem; font-weight: normal; color: var(--text-muted);">
              <em>Location:</em> <%= project.location %>
            </p>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No upcoming service projects listed at this time.</p>
    <% } %>
  </main>
<%- include('partials/footer') %>