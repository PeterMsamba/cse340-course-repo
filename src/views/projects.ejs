<%- include('partials/header') %>
  <main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    
    <% if (projects && projects.length > 0) { %>
      <ul>
        <% projects.forEach(project => { %>
          <li>
            <strong>
              <%= new Date(project.date).toLocaleDateString('en-US', { 
                  month: 'long', 
                  day: 'numeric', 
                  year: 'numeric',
                  timeZone: 'UTC' /* Prevents timezone day shift bugs */
              }) %>:
            </strong>
            <%= project.title %> 
            <span>(<%= project.organization_name %>)</span>
            
            <p style="margin: 0.5rem 0 0 0; font-size: 0.95rem; font-weight: normal; color: var(--text-muted);">
              <em>Location:</em> <%= project.location %> — <%= project.description %>
            </p>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No upcoming service projects listed at this time.</p>
    <% } %>
  </main>
<%- include('partials/footer') %>